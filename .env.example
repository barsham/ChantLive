# Required
DATABASE_URL=postgres://username:password@localhost:5432/chantlive
SESSION_SECRET=replace-with-a-long-random-string

# Optional (enables Google OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional server config
PORT=5000
NODE_ENV=development

# Optional Replit/connector values (used by server/email.ts in Replit environments)
REPLIT_CONNECTORS_HOSTNAME=
REPL_IDENTITY=
WEB_REPL_RENEWAL=
